{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "🚀 OmniStock: 重建并启动 (Up & Build)",
            "type": "shell",
            "command": "docker compose up -d --build",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "clear": true
            }
        },
        {
            "label": "🐳 Docker: 无缓存构建基础镜像",
            "type": "shell",
            "command": "docker build -f Dockerfile.base -t stock-base:latest --no-cache .",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "clear": true
            }
        }
    ]
}